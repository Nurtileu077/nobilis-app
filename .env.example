# Supabase (optional - app works with localStorage)
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# Push Notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
REACT_APP_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@nobilis.edu

# Vercel KV (for push subscriptions storage)
KV_REST_API_URL=
KV_REST_API_TOKEN=
